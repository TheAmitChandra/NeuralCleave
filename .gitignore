# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
backend/.env
frontend/.env
frontend/.env.local
**/.env
**/.env.local
**/.env.production
*.pem
*.key
*.cert

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.lcov

# ── Build artifacts ───────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/node_modules/
*.tsbuildinfo

# ── Docker ────────────────────────────────────────────────────────────────────

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Alembic ───────────────────────────────────────────────────────────────────
# Migration files are committed; only ignore auto-generated __pycache__
backend/alembic/versions/__pycache__/

# ── Local dev tooling binaries (never commit) ─────────────────────────────────
actionlint_bin/
shellcheck_bin/
gh_bin/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tmp
.mypy_cache/
.ruff_cache/

# -- Kubernetes secrets (template committed; real values must never be committed) --
deploy/k8s/secrets.local.yaml

# -- Desktop installers fetched from the latest release at deploy time
# (.github/workflows/deploy-pages.yml) — never committed, only ever
# present transiently in a CI runner's workspace --
docs-site/downloads/
