# ─────────────────────────────────────────────────────────────────────────────
# NeuralCleave Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=NeuralCleave
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_SECRETS_TOKEN_HEX_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Database — PostgreSQL ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cortex:cortex@localhost:5432/neuralcleave
POSTGRES_USER=cortex
POSTGRES_PASSWORD=cortex
POSTGRES_DB=neuralcleave

# ── Database — Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Database — Qdrant ─────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Database — Neo4j ──────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neuralcleave

# ── AI Models ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE
OLLAMA_BASE_URL=http://localhost:11434

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── HashiCorp Vault (optional) ────────────────────────────────────────────────
VAULT_URL=
VAULT_TOKEN=

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090

# ── Frontend (used in production docker-compose) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
