{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "autostart:default",
    "notification:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "cortexflow-backend", "sidecar": true }]
    },
    "shell:allow-kill"
  ]
}
