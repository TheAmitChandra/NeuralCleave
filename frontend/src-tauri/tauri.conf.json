{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CortexFlow-AI",
  "version": "2.0.3",
  "identifier": "ai.cortexflow.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "CortexFlow-AI",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Amit Chandra",
    "copyright": "Copyright © 2026 Amit Chandra",
    "shortDescription": "Personal AI assistant desktop shell",
    "longDescription": "CortexFlow-AI wraps the personal AI assistant web dashboard (memory explorer, channel manager, observability) in a native desktop window.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
